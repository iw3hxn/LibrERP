<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <!-- ============================================================ -->
        <!-- supplier.delay.report — tree / graph / search / action       -->
        <!-- ============================================================ -->

        <record model="ir.ui.view" id="view_supplier_delay_report_tree">
            <field name="name">supplier.delay.report.tree</field>
            <field name="model">supplier.delay.report</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Ritardi ricezione fornitori">
                    <field name="year"/>
                    <field name="partner_id"/>
                    <field name="order_id"/>
                    <field name="picking_id"/>
                    <field name="product_id"/>
                    <field name="date_planned"/>
                    <field name="ddt_in_date"/>
                    <field name="delay_days"/>
                    <field name="late"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="view_supplier_delay_report_graph">
            <field name="name">supplier.delay.report.graph</field>
            <field name="model">supplier.delay.report</field>
            <field name="type">graph</field>
            <field name="arch" type="xml">
                <graph string="Ritardi ricezione fornitori" type="bar">
                    <field name="partner_id"/>
                    <field name="delay_days" operator="+"/>
                </graph>
            </field>
        </record>

        <record model="ir.ui.view" id="view_supplier_delay_report_search">
            <field name="name">supplier.delay.report.search</field>
            <field name="model">supplier.delay.report</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="Ritardi ricezione fornitori">
                    <field name="partner_id" string="Fornitore"/>
                    <field name="year" string="Anno"/>
                    <filter string="In ritardo"
                            name="filter_late"
                            domain="[('delay_days', '&gt;', 0)]"/>
                    <group expand="0" string="Raggruppa per">
                        <filter string="Anno"
                                name="group_year"
                                context="{'group_by': 'year'}"/>
                        <filter string="Fornitore"
                                name="group_partner"
                                context="{'group_by': 'partner_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_supplier_delay_report">
            <field name="name">Ritardi ricezione fornitori</field>
            <field name="res_model">supplier.delay.report</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,graph</field>
            <field name="context">{'search_default_group_year': 1, 'search_default_group_partner': 1}</field>
        </record>

        <!-- ============================================================ -->
        <!-- supplier.nonconformity.report — tree / graph / search / action -->
        <!-- ============================================================ -->

        <record model="ir.ui.view" id="view_supplier_nonconformity_report_tree">
            <field name="name">supplier.nonconformity.report.tree</field>
            <field name="model">supplier.nonconformity.report</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Non conformità fornitori">
                    <field name="year"/>
                    <field name="partner_id"/>
                    <field name="stock_journal_id"/>
                    <field name="picking_name"/>
                    <field name="date"/>
                    <field name="type"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="view_supplier_nonconformity_report_graph">
            <field name="name">supplier.nonconformity.report.graph</field>
            <field name="model">supplier.nonconformity.report</field>
            <field name="type">graph</field>
            <field name="arch" type="xml">
                <graph string="Non conformità fornitori" type="bar">
                    <field name="partner_id"/>
                    <field name="nbr" operator="+"/>
                </graph>
            </field>
        </record>

        <record model="ir.ui.view" id="view_supplier_nonconformity_report_search">
            <field name="name">supplier.nonconformity.report.search</field>
            <field name="model">supplier.nonconformity.report</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="Non conformità fornitori">
                    <field name="partner_id" string="Fornitore"/>
                    <field name="year" string="Anno"/>
                    <field name="stock_journal_id" string="Causale"/>
                    <group expand="0" string="Raggruppa per">
                        <filter string="Anno"
                                name="group_year"
                                context="{'group_by': 'year'}"/>
                        <filter string="Fornitore"
                                name="group_partner"
                                context="{'group_by': 'partner_id'}"/>
                        <filter string="Causale"
                                name="group_journal"
                                context="{'group_by': 'stock_journal_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_supplier_nonconformity_report">
            <field name="name">Non conformità fornitori</field>
            <field name="res_model">supplier.nonconformity.report</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,graph</field>
            <field name="domain">[('type', '=', 'out')]</field>
            <field name="context">{'search_default_group_year': 1, 'search_default_group_partner': 1}</field>
        </record>

        <!-- ============================================================ -->
        <!-- Menu items under Reporting (base.next_id_73)                 -->
        <!-- ============================================================ -->

        <menuitem
            id="menu_supplier_delay_report"
            name="Ritardi ricezione fornitori"
            parent="base.next_id_73"
            action="action_supplier_delay_report"
            sequence="50"/>

        <menuitem
            id="menu_supplier_nonconformity_report"
            name="Non conformità fornitori"
            parent="base.next_id_73"
            action="action_supplier_nonconformity_report"
            sequence="51"/>

        <!-- ============================================================ -->
        <!-- Inherit stock.journal form: add nonconformity booleans       -->
        <!-- ============================================================ -->

        <record model="ir.ui.view" id="view_stock_journal_form_inherit_kpi">
            <field name="name">stock.journal.form.inherit.kpi</field>
            <field name="model">stock.journal</field>
            <field name="type">form</field>
            <field name="inherit_id" ref="stock.view_stock_journal_form"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="nonconformity"/>
                    <field name="nonconformity_check_note"
                           attrs="{'invisible': [('nonconformity', '=', False)]}"/>
                </field>
            </field>
        </record>

    </data>
</openerp>
